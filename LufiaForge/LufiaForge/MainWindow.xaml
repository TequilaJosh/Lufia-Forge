<Window x:Class="LufiaForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LufiaForge.ViewModels"
        xmlns:mm="clr-namespace:LufiaForge.Modules.MemoryMonitor"
        xmlns:te="clr-namespace:LufiaForge.Modules.TextEditor"
        xmlns:tv="clr-namespace:LufiaForge.Modules.TileViewer"
        xmlns:pm="clr-namespace:LufiaForge.Modules.PatchManager"
Title="{Binding WindowTitle}"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Menu bar -->
            <RowDefinition Height="Auto"/> <!-- Toolbar -->
            <RowDefinition Height="Auto"/> <!-- Gold divider -->
            <RowDefinition Height="*"/>    <!-- Tab content -->
            <RowDefinition Height="Auto"/> <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ============================================================
             MENU BAR
             ============================================================ -->
        <Menu Grid.Row="0"
              Background="{StaticResource DeepPurpleBrush}"
              Foreground="{StaticResource TextPrimaryBrush}">

            <MenuItem Header="_File" Foreground="{StaticResource TextPrimaryBrush}">
                <MenuItem Header="Open ROM..."
                          Command="{Binding OpenRomCommand}"
                          InputGestureText="Ctrl+O"
                          Foreground="Black"/>
                <Separator Style="{StaticResource LufiaSeparator}"/>
                <MenuItem Header="Save ROM"
                          Command="{Binding SaveRomCommand}"
                          InputGestureText="Ctrl+S"
                          Foreground="Black"/>
                <MenuItem Header="Save ROM As..."
                          Command="{Binding SaveRomAsCommand}"
                          InputGestureText="Ctrl+Shift+S"
                          Foreground="Black"/>
                <Separator Style="{StaticResource LufiaSeparator}"/>
                <MenuItem Header="Exit" Command="{Binding ExitCommand}" Foreground="Black"/>
            </MenuItem>

            <MenuItem Header="_Help" Foreground="{StaticResource TextPrimaryBrush}">
                <MenuItem Header="About Lufia Forge" Click="AboutMenuItem_Click" Foreground="Black"/>
            </MenuItem>
        </Menu>

        <!-- ============================================================
             TOOLBAR
             ============================================================ -->
        <Border Grid.Row="1"
                Background="{StaticResource ToolbarBackgroundBrush}"
                Padding="8,6">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- App title/logo area -->
                <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                    <TextBlock Text="⚔"
                               FontSize="20"
                               Foreground="{StaticResource GoldBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="LUFIA FORGE"
                               FontFamily="Segoe UI Black"
                               FontSize="15"
                               Foreground="{StaticResource GoldLightBrush}"
                               VerticalAlignment="Center"
                               />
                </StackPanel>

                <Separator Style="{StaticResource LufiaSeparator}" Margin="0,0,16,0"/>

                <Button Content="📂  Open ROM"
                        Style="{StaticResource LufiaButton}"
                        Command="{Binding OpenRomCommand}"
                        Margin="0,0,8,0"/>

                <Button Content="💾  Save ROM"
                        Style="{StaticResource LufiaButton}"
                        Command="{Binding SaveRomCommand}"
                        Margin="0,0,8,0"/>

                <Button Content="Save As..."
                        Style="{StaticResource LufiaButton}"
                        Command="{Binding SaveRomAsCommand}"
                        Margin="0,0,8,0"/>

                <!-- ROM info chip -->
                <Border Background="{StaticResource MidPurpleBrush}"
                        BorderBrush="{StaticResource BorderPurpleBrush}"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="10,4"
                        Margin="16,0,0,0"
                        Visibility="{Binding IsRomLoaded, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8"
                                 Fill="{StaticResource SuccessBrush}"
                                 Margin="0,0,6,0"
                                 VerticalAlignment="Center"/>
                        <TextBlock Style="{StaticResource LufiaLabel}"
                                   Text="ROM Loaded"
                                   Foreground="{StaticResource SuccessBrush}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>

        <!-- Gold accent line -->
        <Rectangle Grid.Row="2" Height="2" Fill="{StaticResource GoldAccentBrush}"/>

        <!-- ============================================================
             MAIN CONTENT - TABS
             ============================================================ -->
        <TabControl Grid.Row="3"
                    Style="{StaticResource LufiaTabControl}"
                    SelectedIndex="{Binding SelectedTabIndex}"
                    Background="Transparent">

            <!-- Memory Monitor (always available, default tab) -->
            <TabItem Header="🔗  Memory Monitor" Style="{StaticResource LufiaTabItem}">
                <mm:MemoryMonitorView x:Name="MemoryMonitorView">
                    <mm:MemoryMonitorView.DataContext>
                        <mm:MemoryMonitorViewModel/>
                    </mm:MemoryMonitorView.DataContext>
                </mm:MemoryMonitorView>
            </TabItem>

            <TabItem Header="📝  Text Editor" Style="{StaticResource LufiaTabItem}">
                <te:TextEditorView x:Name="TextEditorView">
                    <te:TextEditorView.DataContext>
                        <te:TextEditorViewModel/>
                    </te:TextEditorView.DataContext>
                </te:TextEditorView>
            </TabItem>

            <TabItem Header="🎨  Tile Viewer"   Style="{StaticResource LufiaTabItem}">
                <tv:TileViewerView x:Name="TileViewerView">
                    <tv:TileViewerView.DataContext>
                        <tv:TileViewerViewModel/>
                    </tv:TileViewerView.DataContext>
                </tv:TileViewerView>
            </TabItem>

            <TabItem Header="🗺  Map Viewer"    Style="{StaticResource LufiaTabItem}">
                <Border Background="{StaticResource MidPurpleBrush}" Padding="16">
                    <TextBlock Text="Map Viewer - Phase 6"
                               Style="{StaticResource LufiaLabelGold}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </TabItem>

            <TabItem Header="⚙  Disassembler"  Style="{StaticResource LufiaTabItem}">
                <Border Background="{StaticResource MidPurpleBrush}" Padding="16">
                    <TextBlock Text="65816 Disassembler - Phase 5"
                               Style="{StaticResource LufiaLabelGold}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </TabItem>

            <TabItem Header="🩹  Patch Manager" Style="{StaticResource LufiaTabItem}">
                <pm:PatchManagerView x:Name="PatchManagerView">
                    <pm:PatchManagerView.DataContext>
                        <pm:PatchManagerViewModel/>
                    </pm:PatchManagerView.DataContext>
                </pm:PatchManagerView>
            </TabItem>

            <TabItem Header="🔍  ROM Info"      Style="{StaticResource LufiaTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Background="{StaticResource MidPurpleBrush}">
                    <StackPanel Margin="24" MaxWidth="700">
                        <TextBlock Text="ROM Information"
                                   Style="{StaticResource LufiaLabelGold}"
                                   FontSize="18"
                                   Margin="0,0,0,16"/>

                        <!-- ROM detail rows are populated in code-behind -->
                        <ItemsControl x:Name="RomInfoItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Key}"
                                                   Style="{StaticResource LufiaLabel}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Value}"
                                                   Style="{StaticResource LufiaLabel}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- ============================================================
             STATUS BAR
             ============================================================ -->
        <Border Grid.Row="4"
                Background="{StaticResource DeepPurpleBrush}"
                BorderBrush="{StaticResource BorderPurpleBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Style="{StaticResource StatusBarText}"
                               Text="{Binding StatusMessage}"
                               Margin="0,0,16,0"/>
                    <TextBlock Style="{StaticResource StatusBarText}"
                               Text="{Binding StatusDetail}"
                               Foreground="{StaticResource TextDisabledBrush}"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Style="{StaticResource StatusBarText}"
                           Text="Lufia Forge v1.0  |  Lufia 1 US SNES"
                           Foreground="{StaticResource GoldDimBrush}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
