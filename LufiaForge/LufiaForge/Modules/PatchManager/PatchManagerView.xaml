<UserControl x:Class="LufiaForge.Modules.PatchManager.PatchManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource MidPurpleBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL: Actions -->
        <Border Grid.Column="0"
                Background="{StaticResource SurfacePurpleBrush}"
                BorderBrush="{StaticResource BorderPurpleBrush}"
                BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16">

                    <!-- Title -->
                    <TextBlock Text="🩹  IPS Patch Manager"
                               Style="{StaticResource LufiaLabelGold}"
                               FontSize="15"
                               Margin="0,4,0,18"/>

                    <!-- LOAD PATCH section -->
                    <TextBlock Text="LOAD PATCH"
                               Style="{StaticResource LufiaLabel}"
                               Margin="0,0,0,6"/>

                    <Button Content="📂  Load IPS Patch..."
                            Style="{StaticResource LufiaButton}"
                            Command="{Binding LoadPatchCommand}"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,6"/>

                    <Border Background="{StaticResource MidPurpleBrush}"
                            BorderBrush="{StaticResource BorderPurpleBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="8,6"
                            Margin="0,0,0,20">
                        <TextBlock Text="{Binding LoadedPatchName, Mode=OneWay}"
                                   Style="{StaticResource LufiaLabel}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- APPLY PATCH section -->
                    <Separator Style="{StaticResource LufiaSeparator}" Margin="0,0,0,12"/>

                    <TextBlock Text="APPLY TO ROM"
                               Style="{StaticResource LufiaLabel}"
                               Margin="0,0,0,6"/>

                    <TextBlock TextWrapping="Wrap"
                               Style="{StaticResource LufiaLabel}"
                               Text="Applies the loaded patch to the current ROM in memory. The ROM will be marked as unsaved."
                               Margin="0,0,0,8"/>

                    <Button Content="⚡  Apply Patch to ROM"
                            Style="{StaticResource LufiaButtonGold}"
                            Command="{Binding ApplyPatchCommand}"
                            HorizontalAlignment="Stretch"
                            Padding="12,8"
                            Margin="0,0,0,20"/>

                    <!-- EXPORT PATCH section -->
                    <Separator Style="{StaticResource LufiaSeparator}" Margin="0,0,0,12"/>

                    <TextBlock Text="EXPORT PATCH"
                               Style="{StaticResource LufiaLabel}"
                               Margin="0,0,0,6"/>

                    <TextBlock TextWrapping="Wrap"
                               Style="{StaticResource LufiaLabel}"
                               Text="Generates an IPS patch file from the diff between a clean original ROM and your current edits."
                               Margin="0,0,0,8"/>

                    <Button Content="💾  Export IPS Patch..."
                            Style="{StaticResource LufiaButton}"
                            Command="{Binding ExportPatchCommand}"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,20"/>

                    <!-- Status -->
                    <Separator Style="{StaticResource LufiaSeparator}" Margin="0,0,0,12"/>

                    <TextBlock Text="STATUS"
                               Style="{StaticResource LufiaLabel}"
                               Margin="0,0,0,6"/>

                    <TextBlock Text="{Binding StatusText, Mode=OneWay}"
                               Style="{StaticResource LufiaLabel}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap"/>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- RIGHT PANEL: Records list -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header row -->
            <Border Grid.Row="0"
                    Background="{StaticResource SurfacePurpleBrush}"
                    BorderBrush="{StaticResource BorderPurpleBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Offset"
                               Style="{StaticResource LufiaLabel}"
                               Foreground="{StaticResource GoldBrush}"/>
                    <TextBlock Grid.Column="1" Text="Size"
                               Style="{StaticResource LufiaLabel}"
                               Foreground="{StaticResource GoldBrush}"/>
                    <TextBlock Grid.Column="2" Text="Type"
                               Style="{StaticResource LufiaLabel}"
                               Foreground="{StaticResource GoldBrush}"/>
                </Grid>
            </Border>

            <!-- Empty state placeholder -->
            <TextBlock Grid.Row="1"
                       Text="Load an IPS patch file to see its records here."
                       Style="{StaticResource LufiaLabel}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="{Binding HasRecords,
                                    Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

            <!-- Records list -->
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding PatchRecords}"
                     Style="{StaticResource LufiaListBox}"
                     BorderThickness="0"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     Visibility="{Binding HasRecords,
                                  Converter={StaticResource BoolToVisibilityConverter}}">

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource LufiaListBoxItem}">
                        <Setter Property="Padding" Value="12,3"/>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding OffsetDisplay, Mode=OneWay}"
                                       Foreground="{StaticResource GoldLightBrush}"
                                       FontFamily="Consolas" FontSize="12"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SizeDisplay, Mode=OneWay}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Consolas" FontSize="12"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding TypeDisplay, Mode=OneWay}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="Consolas" FontSize="12"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>


            </ListBox>

            <!-- Summary footer -->
            <Border Grid.Row="2"
                    Background="{StaticResource DeepPurpleBrush}"
                    BorderBrush="{StaticResource BorderPurpleBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="12,5">
                <TextBlock Text="{Binding SummaryText, Mode=OneWay}"
                           Style="{StaticResource StatusBarText}"/>
            </Border>

        </Grid>
    </Grid>
</UserControl>
