<UserControl x:Class="LufiaForge.Modules.Emulator.EmulatorHostView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:em="clr-namespace:LufiaForge.Modules.Emulator"
             Background="{StaticResource WindowBackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"   MinWidth="400"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="340" MinWidth="280"/>
        </Grid.ColumnDefinitions>

        <!-- =================================================================
             LEFT — Emulator panel
             ================================================================= -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- toolbar -->
                <RowDefinition Height="Auto"/>   <!-- key bindings panel (collapsible) -->
                <RowDefinition Height="Auto"/>   <!-- config row -->
                <RowDefinition Height="*"/>      <!-- game window -->
                <RowDefinition Height="Auto"/>   <!-- status -->
            </Grid.RowDefinitions>

            <!-- Emulator toolbar -->
            <Border Grid.Row="0"
                    Background="{StaticResource ToolbarBackgroundBrush}"
                    Padding="8,5">
                <WrapPanel Orientation="Horizontal">

                    <Button Content="▶  Launch"
                            Style="{StaticResource LufiaButton}"
                            Command="{Binding LaunchCommand}"
                            Margin="0,0,4,0"/>

                    <Button Content="⏹  Stop"
                            Style="{StaticResource LufiaButton}"
                            Command="{Binding ShutdownEmulatorCommand}"
                            IsEnabled="{Binding IsRunning}"
                            Margin="0,0,8,0"/>

                    <Separator Style="{StaticResource LufiaSeparator}" Margin="0,0,8,0"/>

                    <Button Content="Pause/Resume  F5"
                            Style="{StaticResource LufiaButton}"
                            Command="{Binding ForwardF5Command}"
                            IsEnabled="{Binding IsRunning}"
                            Margin="0,0,4,0"/>

                    <Button Content="Save State  F6"
                            Style="{StaticResource LufiaButton}"
                            Command="{Binding ForwardF6Command}"
                            IsEnabled="{Binding IsRunning}"
                            Margin="0,0,4,0"/>

                    <Button Content="Load State  F7"
                            Style="{StaticResource LufiaButton}"
                            Command="{Binding ForwardF7Command}"
                            IsEnabled="{Binding IsRunning}"
                            Margin="0,0,8,0"/>

                    <Separator Style="{StaticResource LufiaSeparator}" Margin="0,0,8,0"/>

                    <Button Content="🎮  Key Bindings"
                            Style="{StaticResource LufiaButton}"
                            Command="{Binding ToggleKeyBindingsCommand}"
                            Margin="0,0,0,0"/>

                </WrapPanel>
            </Border>

            <!-- Key bindings panel (collapsible) -->
            <Border Grid.Row="1"
                    Background="{StaticResource DeepPurpleBrush}"
                    BorderBrush="{StaticResource BorderPurpleBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="8,6"
                    Visibility="{Binding ShowKeyBindings,
                        Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header row with Reset button -->
                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <TextBlock Text="Controller Key Bindings"
                                   Style="{StaticResource LufiaLabel}"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <Button Content="Reset to Defaults"
                                Style="{StaticResource LufiaButton}"
                                Command="{Binding ResetBindingsCommand}"
                                HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Binding grid: 2 columns × 6 rows = 12 buttons -->
                    <ItemsControl Grid.Row="1"
                                  ItemsSource="{Binding KeyBindings}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" HorizontalAlignment="Stretch"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type em:KeyBindingRow}">
                                <Grid Margin="2,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Label}"
                                               Style="{StaticResource LufiaLabel}"
                                               VerticalAlignment="Center"/>

                                    <!-- Key name / capturing indicator -->
                                    <Border Grid.Column="1"
                                            Background="{StaticResource MidPurpleBrush}"
                                            BorderBrush="{StaticResource BorderPurpleBrush}"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            Padding="6,2"
                                            Margin="0,0,4,0">
                                        <TextBlock VerticalAlignment="Center"
                                                   FontFamily="Cascadia Code, Consolas, monospace"
                                                   FontSize="11">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text"    Value="{Binding KeyName}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCapturing}" Value="True">
                                                            <Setter Property="Text"       Value="Press a key…"/>
                                                            <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <Button Grid.Column="2"
                                            Content="Bind"
                                            Style="{StaticResource LufiaButton}"
                                            FontSize="10"
                                            Padding="5,2"
                                            Command="{Binding DataContext.StartCaptureCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- Config row (shown when not running) -->
            <Border Grid.Row="2"
                    Background="{StaticResource MidPurpleBrush}"
                    BorderBrush="{StaticResource BorderPurpleBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="8,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Style="{StaticResource LufiaTextBox}"
                             Text="{Binding Snes9xPath, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Path to snes9x.exe"
                             IsReadOnly="True"/>
                    <Button  Grid.Column="1"
                             Content="Snes9x..."
                             Style="{StaticResource LufiaButton}"
                             Command="{Binding BrowseSnes9xCommand}"
                             Margin="4,0,0,0"/>

                    <TextBox Grid.Column="3"
                             Style="{StaticResource LufiaTextBox}"
                             Text="{Binding RomPath, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="ROM to load on launch"
                             IsReadOnly="True"/>
                    <Button  Grid.Column="4"
                             Content="ROM..."
                             Style="{StaticResource LufiaButton}"
                             Command="{Binding BrowseRomCommand}"
                             Margin="4,0,0,0"/>
                </Grid>
            </Border>

            <!-- Game window host -->
            <Border Grid.Row="3"
                    Background="Black"
                    x:Name="EmulatorBorder"
                    SizeChanged="EmulatorBorder_SizeChanged">
                <!-- EmulatorHost HwndHost is inserted here in code-behind -->
                <Grid>
                    <!-- Placeholder shown when not running -->
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsRunning,
                                    Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <TextBlock Text="▶"
                                   FontSize="48"
                                   Foreground="{StaticResource GoldDimBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Click Launch to start Snes9x"
                                   Style="{StaticResource LufiaLabel}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="Configure Snes9x path above"
                                   Style="{StaticResource LufiaLabel}"
                                   Foreground="{StaticResource TextDisabledBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <Grid x:Name="EmulatorHostContainer"/>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border Grid.Row="4"
                    Background="{StaticResource DeepPurpleBrush}"
                    Padding="8,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Style="{StaticResource StatusBarText}"
                               Text="{Binding StatusText}"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Ellipse Width="8" Height="8"
                                 Fill="{StaticResource SuccessBrush}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,4,0"
                                 Visibility="{Binding IsAttached,
                                     Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <TextBlock Style="{StaticResource StatusBarText}"
                                   Text="RAM attached"
                                   Foreground="{StaticResource SuccessBrush}"
                                   Visibility="{Binding IsAttached,
                                       Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch"
                      Background="{StaticResource BorderPurpleBrush}"/>

        <!-- =================================================================
             RIGHT — Memory viewer + Watchlist
             ================================================================= -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="300" MinHeight="220"/>
            </Grid.RowDefinitions>

            <!-- Memory viewer header -->
            <Border Grid.Row="0"
                    Background="{StaticResource ToolbarBackgroundBrush}"
                    Padding="8,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Style="{StaticResource LufiaLabel}"
                               Text="RAM $7E:"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"/>

                    <TextBox   Grid.Column="1"
                               Style="{StaticResource LufiaTextBox}"
                               Text="{Binding JumpAddress, UpdateSourceTrigger=PropertyChanged}"
                               ToolTip="Jump to SNES address (hex)"
                               Padding="4,2"
                               FontFamily="Cascadia Code, Consolas, monospace"/>

                    <Button    Grid.Column="2"
                               Content="Go"
                               Style="{StaticResource LufiaButton}"
                               Command="{Binding JumpToAddressCommand}"
                               Margin="4,0,4,0"/>

                    <Button    Grid.Column="3"
                               Content="▲"
                               Style="{StaticResource LufiaButton}"
                               Command="{Binding ScrollRamUpCommand}"
                               Margin="0,0,2,0" Width="24"/>

                    <Button    Grid.Column="4"
                               Content="▼"
                               Style="{StaticResource LufiaButton}"
                               Command="{Binding ScrollRamDownCommand}"
                               Width="24"/>
                </Grid>
            </Border>

            <!-- RAM hex view (monospace text block, scrollable) -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Background="{StaticResource DeepPurpleBrush}">
                <TextBlock Text="{Binding RamHexView}"
                           FontFamily="Cascadia Code, Consolas, Courier New, monospace"
                           FontSize="11"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Padding="6"
                           TextWrapping="NoWrap"/>
            </ScrollViewer>

            <!-- Splitter -->
            <GridSplitter Grid.Row="2"
                          Height="5"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderPurpleBrush}"/>

            <!-- Search + Watchlist tab panel -->
            <TabControl Grid.Row="3"
                        Background="{StaticResource DeepPurpleBrush}"
                        BorderBrush="{StaticResource BorderPurpleBrush}"
                        BorderThickness="0,1,0,0">

                <!-- ═══════════════════════════════════════════════
                     TAB 1 — Memory Search
                     ═══════════════════════════════════════════════ -->
                <TabItem Header="🔍 Search">
                    <Grid Background="{StaticResource DeepPurpleBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- search controls -->
                            <RowDefinition Height="Auto"/>  <!-- status line -->
                            <RowDefinition Height="*"/>     <!-- results list -->
                            <RowDefinition Height="Auto"/>  <!-- action buttons -->
                        </Grid.RowDefinitions>

                        <!-- Search controls -->
                        <Border Grid.Row="0"
                                Background="{StaticResource ToolbarBackgroundBrush}"
                                Padding="6,5">
                            <WrapPanel Orientation="Horizontal">
                                <TextBox Style="{StaticResource LufiaTextBox}"
                                         Text="{Binding SearchValue, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Value to search (decimal or $hex). Not needed for Changed/Increased/etc."
                                         Width="70"
                                         FontFamily="Cascadia Code, Consolas, monospace"
                                         Padding="3,2"
                                         Margin="0,0,4,0"/>

                                <ComboBox Style="{StaticResource LufiaComboBox}"
                                          ItemsSource="{x:Static em:WatchTypeValues.All}"
                                          SelectedItem="{Binding SearchType}"
                                          Width="48"
                                          Padding="3,2"
                                          Margin="0,0,4,0"/>

                                <ComboBox Style="{StaticResource LufiaComboBox}"
                                          ItemsSource="{x:Static em:SearchComparisonValues.All}"
                                          SelectedItem="{Binding SearchComparison}"
                                          Width="88"
                                          Padding="3,2"
                                          Margin="0,0,6,0"/>

                                <Button Content="First Scan"
                                        Style="{StaticResource LufiaButton}"
                                        Command="{Binding FirstScanCommand}"
                                        Margin="0,0,3,0"/>

                                <Button Content="Next Scan"
                                        Style="{StaticResource LufiaButton}"
                                        Command="{Binding NextScanCommand}"
                                        Margin="0,0,3,0"/>

                                <Button Content="Reset"
                                        Style="{StaticResource LufiaButton}"
                                        Command="{Binding ResetSearchCommand}"/>
                            </WrapPanel>
                        </Border>

                        <!-- Status line -->
                        <Border Grid.Row="1"
                                Background="{StaticResource MidPurpleBrush}"
                                Padding="6,3">
                            <TextBlock Text="{Binding SearchStatus}"
                                       Style="{StaticResource LufiaLabel}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Border>

                        <!-- Results list -->
                        <ListView Grid.Row="2"
                                  ItemsSource="{Binding SearchResults}"
                                  SelectedItem="{Binding SelectedSearchResult}"
                                  Background="{StaticResource DeepPurpleBrush}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderThickness="0"
                                  FontFamily="Cascadia Code, Consolas, monospace"
                                  FontSize="11">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Address"  Width="72"
                                                    DisplayMemberBinding="{Binding AddressHex}"/>
                                    <GridViewColumn Header="Current"  Width="62"
                                                    DisplayMemberBinding="{Binding CurrentValue}"/>
                                    <GridViewColumn Header="Previous" Width="62"
                                                    DisplayMemberBinding="{Binding PreviousValue}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <!-- Action buttons -->
                        <Border Grid.Row="3"
                                Background="{StaticResource ToolbarBackgroundBrush}"
                                Padding="4,3">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Style="{StaticResource LufiaLabel}"
                                           FontSize="10"
                                           Foreground="{StaticResource TextDisabledBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           Text="Select a result then:"/>
                                <Button Content="Add to Watchlist"
                                        Style="{StaticResource LufiaButton}"
                                        Command="{Binding AddSearchResultToWatchlistCommand}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ═══════════════════════════════════════════════
                     TAB 2 — Watchlist
                     ═══════════════════════════════════════════════ -->
                <TabItem Header="👁 Watchlist">
                    <Grid Background="{StaticResource DeepPurpleBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Watchlist toolbar -->
                        <Border Grid.Row="0"
                                Background="{StaticResource ToolbarBackgroundBrush}"
                                Padding="6,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Style="{StaticResource LufiaTextBox}"
                                 Text="{Binding NewWatchAddress, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="SNES address (hex, e.g. 7E0000)"
                                 FontFamily="Cascadia Code, Consolas, monospace"
                                 Padding="3,2"/>

                        <TextBox Grid.Column="1"
                                 Style="{StaticResource LufiaTextBox}"
                                 Text="{Binding NewWatchLabel, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Label"
                                 Padding="3,2"
                                 Margin="4,0,4,0"/>

                        <ComboBox Grid.Column="2"
                                  Style="{StaticResource LufiaComboBox}"
                                  ItemsSource="{x:Static em:WatchTypeValues.All}"
                                  SelectedItem="{Binding NewWatchType}"
                                  Padding="3,2"/>

                        <Button  Grid.Column="3"
                                 Content="+"
                                 Style="{StaticResource LufiaButton}"
                                 Command="{Binding AddWatchCommand}"
                                 Margin="4,0,2,0" Width="24"/>

                        <Button  Grid.Column="4"
                                 Content="Export"
                                 Style="{StaticResource LufiaButton}"
                                 Command="{Binding ExportWatchlistCommand}"/>
                    </Grid>
                </Border>

                        <!-- Watchlist grid -->
                        <ListView Grid.Row="1"
                                  ItemsSource="{Binding Watchlist}"
                                  SelectedItem="{Binding SelectedWatch}"
                                  Background="{StaticResource DeepPurpleBrush}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderThickness="0"
                                  FontFamily="Cascadia Code, Consolas, monospace"
                                  FontSize="11">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Address" Width="70"
                                                    DisplayMemberBinding="{Binding AddressHex}"/>
                                    <GridViewColumn Header="Label"   Width="80"
                                                    DisplayMemberBinding="{Binding Label}"/>
                                    <GridViewColumn Header="Type"    Width="40"
                                                    DisplayMemberBinding="{Binding Type}"/>
                                    <GridViewColumn Header="Current" Width="55"
                                                    DisplayMemberBinding="{Binding CurrentValue}"/>
                                    <GridViewColumn Header="Prev"    Width="45"
                                                    DisplayMemberBinding="{Binding PreviousValue}"/>
                                    <GridViewColumn Header="Delta"   Width="45"
                                                    DisplayMemberBinding="{Binding Delta}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <!-- Remove button -->
                        <Button Grid.Row="2"
                                Content="Remove Selected"
                                Style="{StaticResource LufiaButton}"
                                Command="{Binding RemoveWatchCommand}"
                                HorizontalAlignment="Right"
                                Margin="4"/>
                    </Grid>
                </TabItem>

            </TabControl>

        </Grid>
    </Grid>
</UserControl>
