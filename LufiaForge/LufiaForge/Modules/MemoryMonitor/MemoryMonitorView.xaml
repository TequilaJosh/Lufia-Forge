<UserControl x:Class="LufiaForge.Modules.MemoryMonitor.MemoryMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wf="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
             xmlns:local="clr-namespace:LufiaForge.Modules.MemoryMonitor"
             Background="{StaticResource DeepPurpleBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Toolbar / status -->
            <RowDefinition Height="*"/>     <!-- Main content -->
        </Grid.RowDefinitions>

        <!-- ================================================================
             TOP BAR: Launch button + connection status
             ================================================================ -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfacePurpleBrush}"
                BorderBrush="{StaticResource BorderPurpleBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Launch BizHawk"
                        Style="{StaticResource LufiaButtonGold}"
                        Command="{Binding LaunchBizHawkCommand}"
                        Padding="14,6"
                        Margin="0,0,12,0"/>

                <!-- Connection indicator -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource ErrorBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ConnectionStatus}"
                               Style="{StaticResource LufiaLabel}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Column="3"
                           Text="{Binding FrameInfo}"
                           Style="{StaticResource LufiaLabel}"
                           Foreground="{StaticResource GoldDimBrush}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ================================================================
             MAIN: BizHawk (left) + Memory Tools (right)
             ================================================================ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" MinWidth="300"/>  <!-- BizHawk game -->
                <ColumnDefinition Width="Auto"/>               <!-- Splitter -->
                <ColumnDefinition Width="2*" MinWidth="280"/>  <!-- Memory tools -->
            </Grid.ColumnDefinitions>

            <!-- ========== LEFT: Embedded BizHawk ========== -->
            <Border Grid.Column="0"
                    Background="#120C1C"
                    BorderBrush="{StaticResource BorderPurpleBrush}"
                    BorderThickness="0,0,1,0">
                <wf:WindowsFormsHost x:Name="BizHawkFormsHost"
                                     Background="#120C1C"/>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="{StaticResource BorderPurpleBrush}"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- ========== RIGHT: Memory tools sub-tabs ========== -->
            <TabControl Grid.Column="2"
                        Style="{StaticResource LufiaTabControl}"
                        Background="Transparent">

                <!-- ============ HEX VIEW ============ -->
                <TabItem Header="Hex View" Style="{StaticResource LufiaTabItem}">
                    <Grid Background="{StaticResource MidPurpleBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Padding="8,6"
                                Background="{StaticResource SurfacePurpleBrush}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Offset:" Style="{StaticResource LufiaLabel}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Style="{StaticResource LufiaTextBox}"
                                         Text="{Binding HexOffset, UpdateSourceTrigger=PropertyChanged}"
                                         Width="80" Margin="0,0,8,0"/>
                                <Button Content="+" Style="{StaticResource LufiaButton}"
                                        Command="{Binding HexScrollUpCommand}"
                                        Padding="8,2" Margin="0,0,4,0" FontFamily="Consolas" FontWeight="Bold"/>
                                <Button Content="-" Style="{StaticResource LufiaButton}"
                                        Command="{Binding HexScrollDownCommand}"
                                        Padding="8,2" FontFamily="Consolas" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <TextBox Grid.Row="1"
                                 Text="{Binding HexText, Mode=OneWay}"
                                 IsReadOnly="True"
                                 FontFamily="Cascadia Code, Consolas, Courier New"
                                 FontSize="11"
                                 Background="#120C1C"
                                 Foreground="#C8DCFF"
                                 BorderThickness="0"
                                 Padding="6,4"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap"
                                 AcceptsReturn="True"/>
                    </Grid>
                </TabItem>

                <!-- ============ WATCHLIST ============ -->
                <TabItem Header="Watchlist" Style="{StaticResource LufiaTabItem}">
                    <Grid Background="{StaticResource MidPurpleBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Padding="8,6"
                                Background="{StaticResource SurfacePurpleBrush}">
                            <WrapPanel>
                                <TextBox Style="{StaticResource LufiaTextBox}"
                                         Text="{Binding WatchAddrText, UpdateSourceTrigger=PropertyChanged}"
                                         Width="74" Margin="0,0,4,2"
                                         ToolTip="SNES address (hex)"/>
                                <TextBox Style="{StaticResource LufiaTextBox}"
                                         Text="{Binding WatchLabelText, UpdateSourceTrigger=PropertyChanged}"
                                         Width="90" Margin="0,0,4,2"
                                         ToolTip="Label"/>
                                <ComboBox Style="{StaticResource LufiaComboBox}"
                                          ItemsSource="{Binding SizeOptions}"
                                          SelectedIndex="{Binding WatchTypeIndex}"
                                          Width="54" Margin="0,0,4,2"/>
                                <Button Content="+ Add" Style="{StaticResource LufiaButton}"
                                        Command="{Binding AddWatchCommand}"
                                        Padding="8,3" Margin="0,0,0,2"/>
                            </WrapPanel>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Watches}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  SelectionMode="Single"
                                  GridLinesVisibility="Horizontal"
                                  Background="#120C1C"
                                  Foreground="#C8DCFF"
                                  RowBackground="#120C1C"
                                  AlternatingRowBackground="#1A1230"
                                  BorderThickness="0"
                                  FontFamily="Cascadia Code, Consolas, Courier New"
                                  FontSize="11"
                                  HeadersVisibility="Column"
                                  HorizontalGridLinesBrush="#2D1B4E"
                                  ColumnHeaderHeight="26">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#2D1B4E"/>
                                    <Setter Property="Foreground" Value="#E8B84B"/>
                                    <Setter Property="Padding" Value="6,3"/>
                                    <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
                                    <Setter Property="FontSize" Value="10"/>
                                    <Setter Property="BorderBrush" Value="#3D2466"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Addr"    Binding="{Binding AddressHex}"   Width="78"/>
                                <DataGridTextColumn Header="Label"   Binding="{Binding Label}"        Width="90"/>
                                <DataGridTextColumn Header="Cur"     Binding="{Binding CurrentValue}" Width="60"/>
                                <DataGridTextColumn Header="Prev"    Binding="{Binding PreviousValue}" Width="60"/>
                                <DataGridTextColumn Header="Delta"   Binding="{Binding Delta}"        Width="50"/>
                                <DataGridTemplateColumn Header="" Width="40">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="X" FontSize="9" Padding="3,0"
                                                    Command="{Binding DataContext.RemoveWatchCommand,
                                                        RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource LufiaButton}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ============ SEARCH ============ -->
                <TabItem Header="Search" Style="{StaticResource LufiaTabItem}">
                    <Grid Background="{StaticResource MidPurpleBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Padding="8,6"
                                Background="{StaticResource SurfacePurpleBrush}">
                            <WrapPanel>
                                <TextBox Style="{StaticResource LufiaTextBox}"
                                         Text="{Binding SearchValueText, UpdateSourceTrigger=PropertyChanged}"
                                         Width="120" Margin="0,0,4,2"
                                         ToolTip="Value ($hex or decimal)"/>
                                <ComboBox Style="{StaticResource LufiaComboBox}"
                                          ItemsSource="{Binding SizeOptions}"
                                          SelectedIndex="{Binding SearchTypeIndex}"
                                          Width="54" Margin="0,0,4,2"/>
                                <Button Content="First" Style="{StaticResource LufiaButton}"
                                        Command="{Binding FirstScanCommand}"
                                        Padding="8,3" Margin="0,0,2,2"/>
                                <Button Content="Next" Style="{StaticResource LufiaButton}"
                                        Command="{Binding NextScanCommand}"
                                        Padding="8,3" Margin="0,0,2,2"/>
                                <Button Content="Reset" Style="{StaticResource LufiaButton}"
                                        Command="{Binding ResetSearchCommand}"
                                        Padding="8,3" Margin="0,0,0,2"/>
                            </WrapPanel>
                        </Border>

                        <TextBlock Grid.Row="1"
                                   Text="{Binding SearchStatus}"
                                   Style="{StaticResource LufiaLabel}"
                                   Margin="10,4"/>

                        <DataGrid Grid.Row="2"
                                  ItemsSource="{Binding SearchResults}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  SelectionMode="Single"
                                  GridLinesVisibility="Horizontal"
                                  Background="#120C1C"
                                  Foreground="#C8DCFF"
                                  RowBackground="#120C1C"
                                  AlternatingRowBackground="#1A1230"
                                  BorderThickness="0"
                                  FontFamily="Cascadia Code, Consolas, Courier New"
                                  FontSize="11"
                                  HeadersVisibility="Column"
                                  HorizontalGridLinesBrush="#2D1B4E"
                                  ColumnHeaderHeight="26">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#2D1B4E"/>
                                    <Setter Property="Foreground" Value="#E8B84B"/>
                                    <Setter Property="Padding" Value="6,3"/>
                                    <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
                                    <Setter Property="FontSize" Value="10"/>
                                    <Setter Property="BorderBrush" Value="#3D2466"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="90"/>
                                <DataGridTextColumn Header="Value"   Binding="{Binding Value}"   Width="80"/>
                                <DataGridTemplateColumn Header="" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="+Watch" FontSize="9" Padding="4,0"
                                                    Command="{Binding DataContext.AddResultToWatchlistCommand,
                                                        RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource LufiaButton}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>
    </Grid>
</UserControl>
